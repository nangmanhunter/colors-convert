{
  "compilerOptions": {
    /* 💡 최신 TS 6.0+ 컴파일러의 경고를 완벽하게 무력화하는 정석 옵션 */
    "ignoreDeprecations": "6.0",
    
    /* 💡 tsup 내부 엔진이 임의로 baseUrl을 찔러넣지 못하도록 명시적 널(null) 처리 */
    "baseUrl": null,

    /* 1. 빌드 및 모듈 해상도 아키텍처 */
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    /* 2. 전 세계 사용자를 위한 .d.ts 타입 선언 추출 */
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    /* 3. 무결점 철벽 타입 체킹 */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}